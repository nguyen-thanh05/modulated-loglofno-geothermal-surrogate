# LaTeX build artifacts (paper/) — regenerated by compiling paper.tex.
# Scoped to paper/ so generic extensions (*.log, *.out, *.aux) don't catch
# ML logs elsewhere. paper.pdf is ignored by name so figures/*.pdf stay tracked.
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.fdb_latexmk
paper/*.fls
paper/*.log
paper/*.out
paper/*.synctex.gz
paper/*.toc
paper/*.lof
paper/*.lot
paper/*.nav
paper/*.snm
paper/*.vrb
paper/paper.pdf